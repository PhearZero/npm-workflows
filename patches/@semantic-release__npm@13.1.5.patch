diff --git a/lib/trusted-publishing/oidc-context.js b/lib/trusted-publishing/oidc-context.js
index 0427ae9de9da75861b5db715420c9e82a727fbb3..40c553d543c1ac97141acd9171ab9f077eb4d045 100644
--- a/lib/trusted-publishing/oidc-context.js
+++ b/lib/trusted-publishing/oidc-context.js
@@ -2,5 +2,18 @@ import { OFFICIAL_REGISTRY } from "../definitions/constants.js";
 import exchangeToken from "./token-exchange.js";
 
 export default async function oidcContextEstablished(registry, pkg, context) {
-  return OFFICIAL_REGISTRY === registry && !!(await exchangeToken(pkg, context));
+  if (OFFICIAL_REGISTRY !== registry) {
+    return false;
+  }
+
+  const token = await exchangeToken(pkg, context);
+
+  if (token) {
+    context.env.NPM_TOKEN = token;
+    process.env.NPM_TOKEN = token;
+    context.logger.log(`OIDC token obtained and set as NPM_TOKEN`);
+    return true;
+  }
+
+  return false;
 }
