@@ -83,11 +83,15 @@ async function verifyTokenAuth(registry, npmrc, context, pkgRoot) {
 export default async function (npmrc, pkg, { pkgRoot }, context) {
   const registry = getRegistry(pkg, context);
 
-  if (await oidcContextEstablished(registry, pkg, context)) {
-    return;
-  }
+  const isOidc = await oidcContextEstablished(registry, pkg, context);
+  context.logger.log(`[@semantic-release/npm]: isOidc=${isOidc}`);
 
   await setNpmrcAuth(npmrc, registry, context);
 
+  if (isOidc) {
+    context.logger.log(`[@semantic-release/npm]: Skipping verifyTokenAuth because isOidc is true`);
+    return;
+  }
+
   await verifyTokenAuth(registry, npmrc, context, pkgRoot);
 }
